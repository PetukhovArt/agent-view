{
  "name": "@petukhovart/agent-view",
  "version": "0.2.0",
  "description": "CLI tool for visual verification of desktop apps (Electron/Tauri) via Chrome DevTools Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-view": "dist/cli/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "electron",
    "tauri",
    "desktop",
    "testing",
    "accessibility",
    "screenshot",
    "automation",
    "ai-agent",
    "cli"
  ],
  "author": "Artem Petukhov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PetukhovArt/agent-view.git"
  },
  "bugs": {
    "url": "https://github.com/PetukhovArt/agent-view/issues"
  },
  "homepage": "https://github.com/PetukhovArt/agent-view#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
